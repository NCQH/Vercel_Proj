# =============================================================================
# AI TEACHING ASSISTANT - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# AI PROVIDER API KEYS
# -----------------------------------------------------------------------------
# Get OpenAI key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Get Anthropic key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Default model to use (choose one)
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o
# DEFAULT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Direct database connection (for migrations/scripts)
# DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# NEXTAUTH CONFIGURATION
# -----------------------------------------------------------------------------
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here

# URL where your app is hosted
NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_URL=https://your-domain.vercel.app  # For production

# -----------------------------------------------------------------------------
# CHAT & AGENT CONFIGURATION
# -----------------------------------------------------------------------------
# Maximum time (seconds) for agent to process a request before timeout
CHAT_RUN_AGENT_TIMEOUT_SECONDS=35

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# AI HOOK LOGGING (Optional - for instructor monitoring)
# -----------------------------------------------------------------------------
# AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
# AI_LOG_DIR=.ai-log
# AI_LOG_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# CHROMADB CONFIGURATION (Optional - Advanced)
# -----------------------------------------------------------------------------
# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database
# CHROMA_API_KEY=  # Only needed for hosted ChromaDB

# -----------------------------------------------------------------------------
# MEMORY SYSTEM CONFIGURATION (Optional - Advanced)
# -----------------------------------------------------------------------------
# Number of recent conversation turns to include in context
# MEMORY_CONTEXT_TURNS=8

# Number of semantic facts to retrieve
# MEMORY_SEMANTIC_TOP_K=5

# Number of long-term memories to retrieve
# MEMORY_LONG_TERM_TOP_K=4

# Number of episodic memories to retrieve
# MEMORY_EPISODIC_TOP_K=3

# Window size for episodic memory (recent turns)
# MEMORY_EPISODIC_WINDOW=20

# Recency decay for memory ranking (days)
# MEMORY_RECENCY_DECAY_DAYS=30

# Minimum score threshold for memory retrieval
# MEMORY_MIN_SCORE=0.2

# TTL for different memory types (days)
# MEMORY_LONG_TERM_TTL_DAYS=365
# MEMORY_SEMANTIC_TTL_DAYS=365
# MEMORY_EPISODIC_TTL_DAYS=180

# Model to use for memory summarization
# MEMORY_SUMMARY_MODEL=gpt-4o-mini

# Number of turns to summarize
# MEMORY_SUMMARY_TURNS=16

# -----------------------------------------------------------------------------
# RAG CONFIGURATION (Optional - Advanced)
# -----------------------------------------------------------------------------
# Chunk size for document splitting (characters)
# CHUNK_SIZE=400

# Overlap between chunks (characters)
# CHUNK_OVERLAP=80

# Number of documents to retrieve from vector store
# TOP_K_SEARCH=10

# Number of top documents to use for generation
# TOP_K_SELECT=3

# -----------------------------------------------------------------------------
# DEVELOPMENT CONFIGURATION
# -----------------------------------------------------------------------------
# NODE_ENV=development  # development | production | test

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. REQUIRED variables (must be set):
#    - OPENAI_API_KEY or ANTHROPIC_API_KEY (at least one)
#    - SUPABASE_URL
#    - SUPABASE_SERVICE_ROLE_KEY
#    - SUPABASE_ANON_KEY
#    - NEXTAUTH_SECRET
#    - NEXTAUTH_URL
#
# 2. OPTIONAL variables have default values and can be omitted
#
# 3. For production deployment:
#    - Set NEXTAUTH_URL to your actual domain
#    - Use strong NEXTAUTH_SECRET
#    - Consider increasing CHAT_RUN_AGENT_TIMEOUT_SECONDS if needed
#    - Set LOG_LEVEL=WARNING or ERROR to reduce noise
#
# 4. Security:
#    - Never commit .env file to git
#    - Use different secrets for dev/staging/production
#    - Rotate API keys regularly
#    - Use environment-specific Supabase projects
# =============================================================================
